{
  "name": "@unphurl/mcp-server",
  "version": "0.2.3",
  "mcpName": "io.github.123Ergo/unphurl",
  "description": "URL intelligence for AI agents and developers. Structured signals on all URLs. 16 tools, 25 signal weights. 20 free checks.",
  "type": "module",
  "bin": {
    "unphurl-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!')){fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);}fs.chmodSync(f,0o755)\"",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "unphurl",
    "url-intelligence",
    "domain-intelligence",
    "ai-tools",
    "claude",
    "cursor",
    "windsurf"
  ],
  "author": "Erik Goldhar",
  "license": "MIT",
  "homepage": "https://unphurl.com",
  "bugs": {
    "url": "https://github.com/123Ergo/unphurl-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/123Ergo/unphurl-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
